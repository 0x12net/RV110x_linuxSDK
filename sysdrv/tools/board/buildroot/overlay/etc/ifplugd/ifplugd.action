#!/bin/sh
# Called by ifplugd when link state changes.
# $1 = interface name, $2 = "up" or "down"

IFACE="$1"
ACTION="$2"

case "$ACTION" in
  up)
    dhcpcd -k "$IFACE" 2>/dev/null || true
    ip addr flush dev "$IFACE" 2>/dev/null
    ifup "$IFACE"
    ;;
  down)
    dhcpcd -k "$IFACE" 2>/dev/null || true
    ifdown "$IFACE" 2>/dev/null || true
    ip addr flush dev "$IFACE" 2>/dev/null
    ;;
  *)
    echo "Usage: $0 <iface> {up|down}"
    exit 1
esac
